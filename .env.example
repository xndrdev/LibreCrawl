# LibreCrawl Docker Environment Configuration

# Host binding for the application
# - 127.0.0.1 = localhost only (local development)
# - 0.0.0.0 = all interfaces (production, accessible from network)
HOST_BINDING=127.0.0.1

# The port binding for the application
EXTERNAL_PORT=5000

# Local mode - enables auto-login with admin access, no rate limits
# WARNING: "true" disables ALL authentication and grants every visitor admin
# access. Only enable for local development. Keep "false" for any networked or
# production deployment.
LOCAL_MODE=false

# Disable user registrations
# Set to "true" to prevent new users from registering
# Useful for production environments where you only want existing users
REGISTRATION_DISABLED=false

# DANGEROUSLY SKIP AUTH
# Set to "true" to let anyone log in as any username with no password.
# The username is only used to keep per-user sessions separate.
# DO NOT enable on a public network or in production.
DANGEROUSLY_SKIP_AUTH=false

# Email Configuration for verification emails
# SMTP server settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@librecrawl.com
SMTP_FROM_NAME=LibreCrawl

# Base URLs for email links (used to generate verification links)
MAIN_APP_URL=https://crawl.librecrawl.com
WORKSHOP_APP_URL=https://workshop.librecrawl.com
